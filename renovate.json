{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":PRHourlyLimitNone",
    "docker:pinDigests"
  ],
  "enabledManagers": [
    "kubernetes",
    "flux",
    "terraform",
    "ansible"
  ],
  "kubernetes": {
    "fileMatch": [
      "(^|/)k3s/.*\\.ya?ml$"
    ]
  },
  "flux": {
    "fileMatch": [
      "(^|/)k3s/.*\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group Beszel Hub and Agent together",
      "matchPackageNames": [
        "ghcr.io/henrygd/beszel/**"
      ],
      "groupName": "beszel"
    },
    {
      "description": "Group Flux system components",
      "matchPackageNames": [
        "ghcr.io/fluxcd/**"
      ],
      "groupName": "flux-system"
    },
    {
      "description": "Group all linuxserver images (Radarr, Sonarr, Prowlarr, etc)",
      "matchPackageNames": [
        "lscr.io/linuxserver/**",
        "ghcr.io/linuxserver/**",
        "linuxserver/**"
      ],
      "groupName": "linuxserver-apps"
    },
    {
      "description": "Group Intel GPU Device Plugin and Operator",
      "matchPackageNames": [
        "intel/**"
      ],
      "matchSourceUrlPrefixes": [
        "https://github.com/intel/intel-device-plugins-for-kubernetes"
      ],
      "groupName": "intel-device-plugins"
    },
    {
      "description": "Group CloudNativePG components",
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/**",
        "cloudnative-pg/**"
      ],
      "groupName": "cloudnative-pg"
    }
  ]
}
