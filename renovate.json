{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":prHourlyLimitNone",
    "docker:pinDigests"
  ],
  "rebaseWhen": "conflicted",
  "enabledManagers": [
    "kubernetes",
    "flux",
    "terraform",
    "github-actions",
    "custom.regex"
  ],
  "gitAuthor": "Bot <bot@maurovi.ch>",
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "ignoreTests": false,
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)k3s/.*\\.ya?ml$/"
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/(^|/)k3s/.*\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Batch all minor/patch/digest updates — specific groups below override this",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pinDigest"
      ],
      "groupName": "all-non-major"
    },
    {
      "description": "Never automerge major updates - require review",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Disable digest pinning for flux-managed OCI Helm chart refs",
      "matchManagers": [
        "flux"
      ],
      "matchUpdateTypes": [
        "pinDigest"
      ],
      "enabled": false
    },
    {
      "description": "Group Beszel Hub and Agent together",
      "matchPackageNames": [
        "ghcr.io/henrygd/beszel/**"
      ],
      "groupName": "beszel"
    },
    {
      "description": "Group Flux system components",
      "matchPackageNames": [
        "ghcr.io/fluxcd/**"
      ],
      "groupName": "flux-system"
    },
    {
      "description": "Group Intel GPU Device Plugin and Operator",
      "matchPackageNames": [
        "intel/**"
      ],
      "matchSourceUrls": [
        "https://github.com/intel/intel-device-plugins-for-kubernetes"
      ],
      "groupName": "intel-device-plugins"
    },
    {
      "description": "Group CloudNativePG components",
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/**",
        "cloudnative-pg/**"
      ],
      "groupName": "cloudnative-pg"
    },
    {
      "description": "Jellyfin and Jellyseerr are API-coupled — update together",
      "matchPackageNames": [
        "ghcr.io/jellyfin/jellyfin",
        "ghcr.io/fallenbagel/jellyseerr"
      ],
      "groupName": "jellyfin-stack"
    },
    {
      "description": "Media automation pipeline: Prowlarr indexes for Radarr+Sonarr, SABnzbd downloads for both",
      "matchPackageNames": [
        "linuxserver/sonarr",
        "linuxserver/radarr",
        "ghcr.io/linuxserver/prowlarr",
        "linuxserver/sabnzbd"
      ],
      "groupName": "arr-stack"
    },
    {
      "description": "Loki and Promtail must stay version-compatible — same push API",
      "matchManagers": [
        "flux"
      ],
      "matchPackageNames": [
        "loki",
        "promtail"
      ],
      "groupName": "loki-promtail"
    }
  ]
}
