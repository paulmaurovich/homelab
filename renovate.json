{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":prHourlyLimitNone",
    "docker:pinDigests"
  ],
  "enabledManagers": [
    "kubernetes",
    "flux",
    "terraform"
  ],
  "gitAuthor": "Bot <bot@maurovi.ch>",
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": false,
  "minimumReleaseAge": "0 days",
  "ignoreTests": true,
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)k3s/.*\\.ya?ml$/"
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/(^|/)k3s/.*\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Never automerge major updates - require review",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Disable digest pinning for flux-managed OCI Helm chart refs (format incompatible with inline digest injection)",
      "matchManagers": [
        "flux"
      ],
      "matchUpdateTypes": [
        "pinDigest"
      ],
      "enabled": false
    },
    {
      "description": "Group Beszel Hub and Agent together",
      "matchPackageNames": [
        "ghcr.io/henrygd/beszel/**"
      ],
      "groupName": "beszel"
    },
    {
      "description": "Group Flux system components",
      "matchPackageNames": [
        "ghcr.io/fluxcd/**"
      ],
      "groupName": "flux-system"
    },
    {
      "description": "Group all linuxserver images",
      "matchPackageNames": [
        "lscr.io/linuxserver/**",
        "ghcr.io/linuxserver/**",
        "linuxserver/**"
      ],
      "groupName": "linuxserver-apps"
    },
    {
      "description": "Group Intel GPU Device Plugin and Operator",
      "matchPackageNames": [
        "intel/**"
      ],
      "matchSourceUrls": [
        "https://github.com/intel/intel-device-plugins-for-kubernetes"
      ],
      "groupName": "intel-device-plugins"
    },
    {
      "description": "Group CloudNativePG components",
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/**",
        "cloudnative-pg/**"
      ],
      "groupName": "cloudnative-pg"
    }
  ]
}
